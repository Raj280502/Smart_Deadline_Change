# =============================================
# Smart Deadline Change - Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------
# Groq LLM (Required)
# Get key at: https://console.groq.com
# -----------------------------------------
GROQ_API_KEY=your_groq_api_key

# -----------------------------------------
# Telegram Bot (Required for notifications)
# Create bot via @BotFather on Telegram
# -----------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# -----------------------------------------
# Google Cloud (Optional - for Gmail & Calendar)
# Place credentials.json in project root
# token.json will be auto-generated
# -----------------------------------------
# GOOGLE_CREDENTIALS_FILE=credentials.json

# -----------------------------------------
# App Configuration (Optional)
# -----------------------------------------
APP_NAME=Smart Deadline and Change
DEBUG=false
ENABLE_DEADLINE_TRACKER=false
PLACEMENT_CRON_SECRET=change_this_to_a_long_random_cron_secret

# Required in deployment. Use a long random value.
AUTH_SECRET=change_this_to_a_long_random_secret

# -----------------------------------------
# Placement Portal Watcher (Phase 1)
# -----------------------------------------
# Active portal plugin. For now, this project ships with my_college.
PLACEMENT_PORTAL_ADAPTER=my_college

# Your college TPO portal URLs and credentials.
# Do not commit real credentials.
TPO_LOGIN_URL=https://tpo.vierp.in
TPO_HOME_URL=https://tpo.vierp.in/home
TPO_DRIVES_URL=https://tpo.vierp.in/apply_company
TPO_USERNAME=your_tpo_username_or_email
TPO_PASSWORD=your_tpo_password
TPO_HEADLESS=true
PLACEMENT_WATCH_INTERVAL_MINUTES=30

# Temporary selector config for your TPO portal.
# We will replace these with exact selectors after inspecting your portal HTML.
TPO_USERNAME_SELECTOR=input[type='email']
TPO_PASSWORD_SELECTOR=input[type='password']
TPO_SUBMIT_SELECTOR=button[type='submit']
TPO_DRIVE_CARD_SELECTOR=.v-card.v-sheet
TPO_COMPANY_NAME_SELECTOR=.company-name
TPO_ROLE_SELECTOR=.role
TPO_MIN_PACKAGE_SELECTOR=.min-package
TPO_MAX_PACKAGE_SELECTOR=.max-package
TPO_LOCATION_SELECTOR=.location
TPO_DURATION_SELECTOR=.duration
TPO_CRITERIA_SELECTOR=.criteria
TPO_DEADLINE_SELECTOR=.deadline
TPO_DETAIL_LINK_SELECTOR=a
TPO_JD_DOCUMENT_SELECTOR=a[href$='.pdf']
TPO_APPLY_LINK_SELECTOR=a

# Optional model override for JD summaries.
PLACEMENT_SUMMARY_MODEL=llama-3.3-70b-versatile
